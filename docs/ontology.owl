        <rdfs:label xml:lang="en">has report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasRiskDescription -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasRiskDescription">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Description complete of the risk</rdfs:comment>
        <rdfs:label xml:lang="en">has risk ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasRiskID -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasRiskID">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">ID of the risk</rdfs:comment>
        <rdfs:label xml:lang="en">has risk ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasRiskName -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasRiskName">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of the risk</rdfs:comment>
        <rdfs:label xml:lang="en">has risk name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasScope -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasScope">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Scope of the corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">has scope</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasSeverity -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasSeverity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">What severity has the risk</rdfs:comment>
        <rdfs:label xml:lang="en">has severity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasUDIDI -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasUDIDI">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">UDI-DI for the device</rdfs:comment>
        <rdfs:label xml:lang="en">has UDI-DI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isActive -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isActive">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Device has its own energy</rdfs:comment>
        <rdfs:label xml:lang="en">is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isIVD -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isIVD">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Device is In Vitro</rdfs:comment>
        <rdfs:label xml:lang="en">is IVD</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isImplantable -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isImplantable">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Device is implanted in patient</rdfs:comment>
        <rdfs:label xml:lang="en">is implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isReusable -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isReusable">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicate if the device can be usable more of one time</rdfs:comment>
        <rdfs:label xml:lang="en">is reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#ActiveDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Type of device that it uses energy itself for run without energy of human body o gravitiy</rdfs:comment>
        <rdfs:label xml:lang="en">ActiveDevice</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#ActiveImplant -->


    <owl:Class rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#ActiveImplant">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Type of device that it uses energy from battery without energy of the human body or gravity and it implants in the patient.</rdfs:comment>
        <rdfs:label xml:lang="en">ActiveImplant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#CompetentAuthority -->


    <owl:Class rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#CompetentAuthority">
        <rdfs:comment xml:lang="en">Competent authority that audit manufacturers</rdfs:comment>
        <rdfs:label xml:lang="en">CompetentAuthority</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#CorrectiveAction -->


    <owl:Class rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#CorrectiveAction">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#fixIncident"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Incident"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">Corrective action that fix an incident</rdfs:comment>
        <rdfs:label xml:lang="en">CorrectiveAction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Country -->


    <owl:Class rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Country">
        <rdfs:comment xml:lang="en">Country of the world</rdfs:comment>
        <rdfs:label xml:lang="en">Country</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#ImplantableDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#ImplantableDevice">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isActive"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isImplantable"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Type of device that implants in the patient</rdfs:comment>
        <rdfs:label xml:lang="en">ImplantableDevice</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#InSituCorrection -->


    <owl:Class rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#InSituCorrection">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Correction do In Situ</rdfs:comment>
        <rdfs:label xml:lang="en">InSituCorrection</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#InVitroDiagnosticDevice">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isIVD"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Type of device that uses non-invasive in the patient</rdfs:comment>
        <rdfs:label xml:lang="en">InVitroDiagnosticDevice</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Incident -->


    <owl:Class rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Incident">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#affectTo"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">Incdident that can occurs on a device</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Manufacturer -->


    <owl:Class rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Manufacturer">
        <rdfs:comment xml:lang="en">The manufacturer of the devices</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isManufacturerBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Manufacturer"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">Medical devices manufacturer to fix some medical issue</rdfs:comment>
        <rdfs:label xml:lang="en">MedicalDevice</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#NearMissIncident -->


    <owl:Class rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#NearMissIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Incident"/>
        <rdfs:comment xml:lang="en">Incident without series consequences</rdfs:comment>
        <rdfs:label xml:lang="en">NearMissIncident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Recall -->


    <owl:Class rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Recall">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Recall to user</rdfs:comment>
        <rdfs:label xml:lang="en">Recall</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#RegulationFramework -->


    <owl:Class rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#RegulationFramework">
        <rdfs:comment xml:lang="en">Regulation Framework under the device is manufactured</rdfs:comment>
        <rdfs:label xml:lang="en">RegulationFramework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Risk -->


    <owl:Class rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Risk">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#RiskAffectsToMD"/>
