        <hasActionDate xml:lang="en">2024-03-15</hasActionDate>
        <hasActionDescription xml:lang="en">Enhanced deployment training and updated IFU for Portico valve implantation technique. New implantation checklist mandatory for all TAVI centres.</hasActionDescription>
