            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasType"/>
