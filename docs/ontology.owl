<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#"
     xml:base="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:MedicalDevices-PEC2-ontology="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#">
        <owl:versionIRI rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#1.0.0"/>
        <dc:creator xml:lang="en">Antonio Sáez Jiménez</dc:creator>
        <dc:title xml:lang="en">Medical Devices under PEC2 to UOC</dc:title>
        <rdfs:comment xml:lang="en">This is an ontology for PEC2 on second semester in IT Grade of course 2025-2026. This ontologý has been realized by Antonio Sáez Jiménez</rdfs:comment>
        <rdfs:isDefinedBy xml:lang="en">Antonio Sáez Jiménez</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Medical Devices UOC</rdfs:label>
        <owl:versionInfo xml:lang="en">1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://www.w3.org/2002/07/owl#sameAs -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2002/07/owl#sameAs"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
