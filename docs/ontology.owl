    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#FSCA_001 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#FSCA_001">
        <rdf:type rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#SafetyAlert"/>
        <fixIncident rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#INC_001"/>
        <hasActionDate xml:lang="en">2024-02-01</hasActionDate>
        <hasActionDescription xml:lang="en">Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0.</hasActionDescription>
        <hasActionStatus xml:lang="en">Open</hasActionStatus>
        <hasCountriesAffected xml:lang="en">EU-wide</hasCountriesAffected>
        <hasDevicesAffected xml:lang="en">850</hasDevicesAffected>
        <hasEUDAMEDFscaRef xml:lang="en">EU-FSCA-2024-000001</hasEUDAMEDFscaRef>
        <hasScope xml:lang="en">All HeartMate 3 LVAD units implanted since 2020</hasScope>
        <rdfs:comment xml:lang="en">This is the corrective action taken to incident 001</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA 001</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#FSCA_003 -->


