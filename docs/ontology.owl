    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#RiskAffectsToMD -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#RiskAffectsToMD">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Risk affects to Medical Device</rdfs:comment>
        <rdfs:label xml:lang="en">Risk affects to MD</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#affectTo -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#affectTo">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Incident that affects to device</rdfs:comment>
        <rdfs:label xml:lang="en">Incident affects to MD</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#fixIncident -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#fixIncident">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Incident"/>
        <rdfs:comment xml:lang="en">Corrective action that fix an incident</rdfs:comment>
        <rdfs:label xml:lang="en">fix incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasCategory -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasCategory">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#RiskCategory"/>
        <rdfs:comment xml:lang="en">Which type of category the risk is</rdfs:comment>
        <rdfs:label xml:lang="en">has category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasRiskClass">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#RiskClass"/>
        <rdfs:comment xml:lang="en">Relates a device to its MDR/IVDR risk class</rdfs:comment>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasType -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#RiskType"/>
        <rdfs:comment xml:lang="en">Which type the risk is</rdfs:comment>
        <rdfs:label xml:lang="en">has type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isManufacturerBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isManufacturerBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Manufacturer"/>
        <rdfs:comment xml:lang="en">Who entity manufacture the device</rdfs:comment>
        <rdfs:label xml:lang="en">is manufacturer by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isNotifiedBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isNotifiedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Manufacturer"/>
        <rdfs:comment xml:lang="en">Which manufacturer notifies an incident on their devices</rdfs:comment>
        <rdfs:label xml:lang="en">is notified by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isPlacedIn -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isPlacedIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Country"/>
        <rdfs:comment xml:lang="en">Country where the manufacturer base is installed</rdfs:comment>
        <rdfs:label xml:lang="en">is placed in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isRegulatedBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isRegulatedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#RegulationFramework"/>
        <rdfs:comment xml:lang="en">Relates devices with the Regulation Framework (MDR/IVDR)</rdfs:comment>
        <rdfs:label xml:lang="en">is regulated by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isRelatedWith -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isRelatedWith">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Risk"/>
        <rdfs:comment xml:lang="en">Which incidents is related with Risks</rdfs:comment>
        <rdfs:label xml:lang="en">is related with</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isReportedOn -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isReportedOn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Country"/>
        <rdfs:comment xml:lang="en">Country where the incident occurs</rdfs:comment>
        <rdfs:label xml:lang="en">is reported on</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isUnderAuthority -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isUnderAuthority">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#CompetentAuthority"/>
        <rdfs:comment xml:lang="en">Which competent authority regulates manufacturers</rdfs:comment>
        <rdfs:label xml:lang="en">is under authority</rdfs:label>
    </owl:ObjectProperty>
    


