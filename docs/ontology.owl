        <hasClosureDate xml:lang="en">2024-06-30</hasClosureDate>
        <hasCountriesAffected xml:lang="en">EU-wide + UK</hasCountriesAffected>
        <hasDevicesAffected xml:lang="en">320</hasDevicesAffected>
        <hasEUDAMEDFscaRef xml:lang="en">EU-FSCA-2024-000003</hasEUDAMEDFscaRef>
        <hasScope xml:lang="en">Portico THV sizes 23mm and 25mm from lots before 2023-11</hasScope>
        <rdfs:comment xml:lang="en">This is the corrective action to fix incident 003</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA 003</rdfs:label>
    </owl:NamedIndividual>
    


