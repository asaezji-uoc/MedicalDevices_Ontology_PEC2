        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">What probability exists risk occurs</rdfs:comment>
        <rdfs:label xml:lang="en">has probability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasReportDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasReportDate">
