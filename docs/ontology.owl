        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Start date  of the corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">has action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasActionDescription -->


