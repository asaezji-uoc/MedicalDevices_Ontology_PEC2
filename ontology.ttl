@prefix : <http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#> .

<http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#> rdf:type owl:Ontology ;
                                                                                   owl:versionIRI <http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#1.0.0> ;
                                                                                   <http://purl.org/dc/elements/1.1/creator> "Antonio Sáez Jiménez"@en ;
                                                                                   <http://purl.org/dc/elements/1.1/title> "Medical Devices under PEC2 to UOC"@en ;
                                                                                   rdfs:comment "This is an ontology for PEC2 on second semester in IT Grade of course 2025-2026. This ontologý has been realized by Antonio Sáez Jiménez"@en ;
                                                                                   rdfs:isDefinedBy "Antonio Sáez Jiménez"@en ;
                                                                                   rdfs:label "Medical Devices UOC"@en ;
                                                                                   owl:versionInfo "1.0"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#sameAs
owl:sameAs rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#RiskAffectsToMD
:RiskAffectsToMD rdf:type owl:ObjectProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range :MedicalDevice ;
                 rdfs:comment "Risk affects to Medical Device"@en ;
                 rdfs:label "Risk affects to MD"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#affectTo
:affectTo rdf:type owl:ObjectProperty ;
          rdfs:domain :Incident ;
          rdfs:range :MedicalDevice ;
          rdfs:comment "Incident that affects to device"@en ;
          rdfs:label "Incident affects to MD"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#fixIncident
:fixIncident rdf:type owl:ObjectProperty ;
             rdfs:domain :CorrectiveAction ;
             rdfs:range :Incident ;
             rdfs:comment "Corrective action that fix an incident"@en ;
             rdfs:label "fix incident"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasCategory
:hasCategory rdf:type owl:ObjectProperty ;
             rdfs:domain :Risk ;
             rdfs:range :RiskCategory ;
             rdfs:comment "Which type of category the risk is"@en ;
             rdfs:label "has category"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasRiskClass
:hasRiskClass rdf:type owl:ObjectProperty ;
              rdfs:domain :MedicalDevice ;
              rdfs:range :RiskClass ;
              rdfs:comment "Relates a device to its MDR/IVDR risk class"@en ;
              rdfs:label "has risk class"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasType
:hasType rdf:type owl:ObjectProperty ;
         rdfs:domain :Risk ;
         rdfs:range :RiskType ;
         rdfs:comment "Which type the risk is"@en ;
         rdfs:label "has type"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isManufacturerBy
:isManufacturerBy rdf:type owl:ObjectProperty ;
                  rdfs:domain :MedicalDevice ;
                  rdfs:range :Manufacturer ;
                  rdfs:comment "Who entity manufacture the device"@en ;
                  rdfs:label "is manufacturer by"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isNotifiedBy
:isNotifiedBy rdf:type owl:ObjectProperty ;
              rdfs:domain :Incident ;
              rdfs:range :Manufacturer ;
              rdfs:comment "Which manufacturer notifies an incident on their devices"@en ;
              rdfs:label "is notified by"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isPlacedIn
:isPlacedIn rdf:type owl:ObjectProperty ;
            rdfs:domain :Manufacturer ;
            rdfs:range :Country ;
            rdfs:comment "Country where the manufacturer base is installed"@en ;
            rdfs:label "is placed in"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isRegulatedBy
:isRegulatedBy rdf:type owl:ObjectProperty ;
               rdfs:domain :MedicalDevice ;
               rdfs:range :RegulationFramework ;
               rdfs:comment "Relates devices with the Regulation Framework (MDR/IVDR)"@en ;
               rdfs:label "is regulated by"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isRelatedWith
:isRelatedWith rdf:type owl:ObjectProperty ;
               rdfs:domain :Incident ;
               rdfs:range :Risk ;
               rdfs:comment "Which incidents is related with Risks"@en ;
               rdfs:label "is related with"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isReportedOn
:isReportedOn rdf:type owl:ObjectProperty ;
              rdfs:domain :Incident ;
              rdfs:range :Country ;
              rdfs:comment "Country where the incident occurs"@en ;
              rdfs:label "is reported on"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isUnderAuthority
:isUnderAuthority rdf:type owl:ObjectProperty ;
                  rdfs:domain :Manufacturer ;
                  rdfs:range :CompetentAuthority ;
                  rdfs:comment "Which competent authority regulates manufacturers"@en ;
                  rdfs:label "is under authority"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasActionDate
:hasActionDate rdf:type owl:DatatypeProperty ;
               rdfs:domain :CorrectiveAction ;
               rdfs:range xsd:dateTime ;
               rdfs:comment "Start date  of the corrective action"@en ;
               rdfs:label "has action date"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasActionDescription
:hasActionDescription rdf:type owl:DatatypeProperty ;
                      rdfs:domain :CorrectiveAction ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Description of the corrective action"@en ;
                      rdfs:label "has action description"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasActionStatus
:hasActionStatus rdf:type owl:DatatypeProperty ;
                 rdfs:domain :CorrectiveAction ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Status of the corrective action"@en ;
                 rdfs:label "has action status"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasAuthorizationNumber
:hasAuthorizationNumber rdf:type owl:DatatypeProperty ;
                        rdfs:domain :Manufacturer ;
                        rdfs:range xsd:string ;
                        rdfs:comment "Authorization number of the manufacturer"@en ;
                        rdfs:label "has authorization number"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasClosureDate
:hasClosureDate rdf:type owl:DatatypeProperty ;
                rdfs:domain :CorrectiveAction ;
                rdfs:range xsd:dateTime ;
                rdfs:comment "Closure date for corrective action"@en ;
                rdfs:label "has closure date"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasContactEmail
:hasContactEmail rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Manufacturer ;
                 rdfs:range xsd:string ;
                 rdfs:comment "eMail of contact with manufacturer"@en ;
                 rdfs:label "has contact eMail"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasCorrectiveActionTaken
:hasCorrectiveActionTaken rdf:type owl:DatatypeProperty ;
                          rdfs:domain :Incident ;
                          rdfs:range xsd:boolean ;
                          rdfs:comment "Indicate if corrective action is taken"@en ;
                          rdfs:label "has corrective action taken"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasCountriesAffected
:hasCountriesAffected rdf:type owl:DatatypeProperty ;
                      rdfs:domain :CorrectiveAction ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Countries affected"@en ;
                      rdfs:label "has countries affected"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasDetectionDate
:hasDetectionDate rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Incident ;
                  rdfs:range xsd:dateTime ;
                  rdfs:comment "Date when incident is detected"@en ;
                  rdfs:label "has detection date"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasDeviceId
:hasDeviceId rdf:type owl:DatatypeProperty ;
             rdfs:domain :MedicalDevice ;
             rdfs:range xsd:string ;
             rdfs:comment "Device ID"@en ;
             rdfs:label "has device ID"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasDeviceName
:hasDeviceName rdf:type owl:DatatypeProperty ;
               rdfs:domain :MedicalDevice ;
               rdfs:range xsd:string ;
               rdfs:comment "Device name"@en ;
               rdfs:label "has device name"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasDevicesAffected
:hasDevicesAffected rdf:type owl:DatatypeProperty ;
                    rdfs:domain :CorrectiveAction ;
                    rdfs:range xsd:integer ;
                    rdfs:comment "Number of devices affected"@en ;
                    rdfs:label "has devices affected"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasEUDAMEDFscaRef
:hasEUDAMEDFscaRef rdf:type owl:DatatypeProperty ;
                   rdfs:domain :CorrectiveAction ;
                   rdfs:range xsd:string ;
                   rdfs:comment "EUDAMED Reference"@en ;
                   rdfs:label "has EUDAMED Reference"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasEUDAMEDIncidentRef
:hasEUDAMEDIncidentRef rdf:type owl:DatatypeProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:string ;
                       rdfs:comment "EUDAMED reference of incident"@en ;
                       rdfs:label "has EUDAMED reference"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasEudamedSRN
:hasEudamedSRN rdf:type owl:DatatypeProperty ;
               rdfs:domain :Manufacturer ;
               rdfs:range xsd:string ;
               rdfs:comment "EUDAMED serial number of the manufacturer"@en ;
               rdfs:label "has EUDAMED serial number"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasEventDate
:hasEventDate rdf:type owl:DatatypeProperty ;
              rdfs:domain :Incident ;
              rdfs:range xsd:dateTime ;
              rdfs:comment "Date when the incident occurs"@en ;
              rdfs:label "has event date"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasFscaID
:hasFscaID rdf:type owl:DatatypeProperty ;
           rdfs:domain :CorrectiveAction ;
           rdfs:range xsd:string ;
           rdfs:comment "ID of the corrective action"@en ;
           rdfs:label "has ID"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasIMDRFCode
:hasIMDRFCode rdf:type owl:DatatypeProperty ;
              rdfs:domain :Risk ;
              rdfs:range xsd:string ;
              rdfs:comment "IMDRF Code"@en ;
              rdfs:label "has IMDRF code"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasIncidentDescription
:hasIncidentDescription rdf:type owl:DatatypeProperty ;
                        rdfs:domain :Incident ;
                        rdfs:range xsd:string ;
                        rdfs:comment "Complete description of the incident"@en ;
                        rdfs:label "has incident description"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasIncidentID
:hasIncidentID rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:string ;
               rdfs:comment "ID of the incident"@en ;
               rdfs:label "has incident ID"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasIntendedPurpose
:hasIntendedPurpose rdf:type owl:DatatypeProperty ;
                    rdfs:domain :MedicalDevice ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Purpose of device"@en ;
                    rdfs:label "has intended purpose"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasManufacturerID
:hasManufacturerID rdf:type owl:DatatypeProperty ;
                   rdfs:domain :Manufacturer ;
                   rdfs:range xsd:string ;
                   rdfs:comment "ID of the manufacturer"@en ;
                   rdfs:label "has manufacturer ID"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasManufacturerName
:hasManufacturerName rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Name of the manufacturer"@en ;
                     rdfs:label "has manufacturer name"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasOutcome
:hasOutcome rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "Outcome occurs on the patient"@en ;
            rdfs:label "has outcome"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasPatientAge
:hasPatientAge rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:decimal ;
               rdfs:comment "Patient age when the incident occurs"@en ;
               rdfs:label "has patient age"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasPatientSex
:hasPatientSex rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:string ;
               rdfs:comment "Patient sex"@en ;
               rdfs:label "has patient sex"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasProbability
:hasProbability rdf:type owl:DatatypeProperty ;
                rdfs:domain :Risk ;
                rdfs:range xsd:string ;
                rdfs:comment "What probability exists risk occurs"@en ;
                rdfs:label "has probability"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasReportDate
:hasReportDate rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:dateTime ;
               rdfs:comment "Date when the incident is reported"@en ;
               rdfs:label "has report date"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasRiskDescription
:hasRiskDescription rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Risk ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Description complete of the risk"@en ;
                    rdfs:label "has risk ID"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasRiskID
:hasRiskID rdf:type owl:DatatypeProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string ;
           rdfs:comment "ID of the risk"@en ;
           rdfs:label "has risk ID"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasRiskName
:hasRiskName rdf:type owl:DatatypeProperty ;
             rdfs:domain :Risk ;
             rdfs:range xsd:string ;
             rdfs:comment "Name of the risk"@en ;
             rdfs:label "has risk name"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasScope
:hasScope rdf:type owl:DatatypeProperty ;
          rdfs:domain :CorrectiveAction ;
          rdfs:range xsd:string ;
          rdfs:comment "Scope of the corrective action"@en ;
          rdfs:label "has scope"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasSeverity
:hasSeverity rdf:type owl:DatatypeProperty ;
             rdfs:domain :Risk ;
             rdfs:range xsd:string ;
             rdfs:comment "What severity has the risk"@en ;
             rdfs:label "has severity"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#hasUDIDI
:hasUDIDI rdf:type owl:DatatypeProperty ;
          rdfs:domain :MedicalDevice ;
          rdfs:range xsd:string ;
          rdfs:comment "UDI-DI for the device"@en ;
          rdfs:label "has UDI-DI"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isActive
:isActive rdf:type owl:DatatypeProperty ;
          rdfs:domain :MedicalDevice ;
          rdfs:range xsd:boolean ;
          rdfs:comment "Device has its own energy"@en ;
          rdfs:label "is active"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isIVD
:isIVD rdf:type owl:DatatypeProperty ;
       rdfs:domain :MedicalDevice ;
       rdfs:range xsd:boolean ;
       rdfs:comment "Device is In Vitro"@en ;
       rdfs:label "is IVD"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isImplantable
:isImplantable rdf:type owl:DatatypeProperty ;
               rdfs:domain :MedicalDevice ;
               rdfs:range xsd:boolean ;
               rdfs:comment "Device is implanted in patient"@en ;
               rdfs:label "is implantable"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#isReusable
:isReusable rdf:type owl:DatatypeProperty ;
            rdfs:domain :MedicalDevice ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Indicate if the device can be usable more of one time"@en ;
            rdfs:label "is reusable"@en .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#ActiveDevice
:ActiveDevice rdf:type owl:Class ;
              rdfs:subClassOf :MedicalDevice ;
              rdfs:comment "Type of device that it uses energy itself for run without energy of human body o gravitiy"@en ;
              rdfs:label "ActiveDevice"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#ActiveImplant
:ActiveImplant rdf:type owl:Class ;
               rdfs:subClassOf :MedicalDevice ;
               rdfs:comment "Type of device that it uses energy from battery without energy of the human body or gravity and it implants in the patient."@en ;
               rdfs:label "ActiveImplant"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#CompetentAuthority
:CompetentAuthority rdf:type owl:Class ;
                    rdfs:comment "Competent authority that audit manufacturers"@en ;
                    rdfs:label "CompetentAuthority"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Restriction ;
                                        owl:onProperty :fixIncident ;
                                        owl:someValuesFrom :Incident
                                      ] ;
                  rdfs:comment "Corrective action that fix an incident"@en ;
                  rdfs:label "CorrectiveAction"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Country
:Country rdf:type owl:Class ;
         rdfs:comment "Country of the world"@en ;
         rdfs:label "Country"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#ImplantableDevice
:ImplantableDevice rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( :MedicalDevice
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty :isActive ;
                                                                owl:hasValue "true"^^xsd:boolean
                                                              ]
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty :isImplantable ;
                                                                owl:hasValue "true"^^xsd:boolean
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   rdfs:subClassOf :MedicalDevice ;
                   rdfs:comment "Type of device that implants in the patient"@en ;
                   rdfs:label "ImplantableDevice"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#InSituCorrection
:InSituCorrection rdf:type owl:Class ;
                  rdfs:subClassOf :CorrectiveAction ;
                  rdfs:comment "Correction do In Situ"@en ;
                  rdfs:label "InSituCorrection"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         owl:equivalentClass [ owl:intersectionOf ( :MedicalDevice
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty :isIVD ;
                                                                      owl:hasValue "true"^^xsd:boolean
                                                                    ]
                                                                  ) ;
                                               rdf:type owl:Class
                                             ] ;
                         rdfs:subClassOf :MedicalDevice ;
                         rdfs:comment "Type of device that uses non-invasive in the patient"@en ;
                         rdfs:label "InVitroDiagnosticDevice"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Incident
:Incident rdf:type owl:Class ;
          owl:equivalentClass [ rdf:type owl:Restriction ;
                                owl:onProperty :affectTo ;
                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :MedicalDevice
                              ] ;
          rdfs:comment "Incdident that can occurs on a device"@en ;
          rdfs:label "Incident"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:comment "The manufacturer of the devices"@en ;
              rdfs:label "Manufacturer"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#MedicalDevice
:MedicalDevice rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Restriction ;
                                     owl:onProperty :isManufacturerBy ;
                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onClass :Manufacturer
                                   ] ;
               rdfs:comment "Medical devices manufacturer to fix some medical issue"@en ;
               rdfs:label "MedicalDevice"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#NearMissIncident
:NearMissIncident rdf:type owl:Class ;
                  rdfs:subClassOf :Incident ;
                  rdfs:comment "Incident without series consequences"@en ;
                  rdfs:label "NearMissIncident"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :CorrectiveAction ;
        rdfs:comment "Recall to user"@en ;
        rdfs:label "Recall"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#RegulationFramework
:RegulationFramework rdf:type owl:Class ;
                     rdfs:comment "Regulation Framework under the device is manufactured"@en ;
                     rdfs:label "RegulationFramework"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#Risk
:Risk rdf:type owl:Class ;
      owl:equivalentClass [ rdf:type owl:Restriction ;
                            owl:onProperty :RiskAffectsToMD ;
                            owl:someValuesFrom :MedicalDevice
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasCategory ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :RiskCategory
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasType ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :RiskCategory
                          ] ;
      rdfs:comment "Risk known on the device"@en ;
      rdfs:label "Risk"@en .


