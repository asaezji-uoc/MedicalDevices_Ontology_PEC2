###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :Incident ;
                 rdfs:comment "Incident with serious consequences"@en ;
                 rdfs:label "SeriousIncident"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#SingleUseDevice
:SingleUseDevice rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( :MedicalDevice
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :isActive ;
                                                              owl:hasValue "false"^^xsd:boolean
                                                            ]
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :isIVD ;
                                                              owl:hasValue "false"^^xsd:boolean
                                                            ]
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :isImplantable ;
                                                              owl:hasValue "false"^^xsd:boolean
                                                            ]
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :isReusable ;
                                                              owl:hasValue "false"^^xsd:boolean
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:subClassOf :MedicalDevice ;
                 rdfs:comment "This device is for use one time. It isn't reusable."@en ;
                 rdfs:label "SingleUSeDevice"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#UserNotice
:UserNotice rdf:type owl:Class ;
            rdfs:subClassOf :CorrectiveAction ;
            rdfs:comment "User has noticed"@en ;
            rdfs:label "UserNotice"@en .


