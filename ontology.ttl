:FSCA_001 rdf:type owl:NamedIndividual ,
                   :SafetyAlert ;
          :fixIncident :INC_001 ;
          :hasActionDate "2024-02-01"@en ;
          :hasActionDescription "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0."@en ;
          :hasActionStatus "Open"@en ;
          :hasCountriesAffected "EU-wide"@en ;
          :hasDevicesAffected "850"@en ;
          :hasEUDAMEDFscaRef "EU-FSCA-2024-000001"@en ;
          :hasScope "All HeartMate 3 LVAD units implanted since 2020"@en ;
          rdfs:comment "This is the corrective action taken to incident 001"@en ;
          rdfs:label "FSCA 001"@en .


###  http://www.semanticweb.org/toño/ontologies/2026/3/MedicalDevices-PEC2-ontology#FSCA_003
:FSCA_003 rdf:type owl:NamedIndividual ,
                   :InSituCorrection ;
          :fixIncident :INC_003 ;
          :hasActionDate "2024-03-15"@en ;
          :hasActionDescription "Enhanced deployment training and updated IFU for Portico valve implantation technique. New implantation checklist mandatory for all TAVI centres."@en ;
